NEXT_PUBLIC_SITE_URL=https://bhoomikonnect.com
ENABLE_DEMO_CONTENT=false
NEXT_PUBLIC_PRIMARY_PHONE=+91 90000 00000
NEXT_PUBLIC_WHATSAPP_NUMBER=919000000000
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_OFFICE_ADDRESS=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_FACEBOOK_URL=

# Optional Directus CMS override
# Use DIRECTUS_URL for server-side fetches. NEXT_PUBLIC_DIRECTUS_URL is only needed
# if you want Next/Image to allow Directus asset URLs at build time.
DIRECTUS_URL=
NEXT_PUBLIC_DIRECTUS_URL=
DIRECTUS_STATIC_TOKEN=
DIRECTUS_CACHE_SECONDS=60

# Supabase database, authentication, storage, and included CMS
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Transactional email and administrator identity
RESEND_API_KEY=
RESEND_FROM_EMAIL=BhoomiKonnect <leads@your-domain.com>
ADMIN_EMAIL=admin@example.com
LEAD_NOTIFICATION_EMAILS=admin@example.com,sales@example.com
SEND_CUSTOMER_CONFIRMATION_EMAIL=true

# Optional paid Twilio SMS notifications (use E.164 numbers)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
LEAD_SMS_TO=
SEND_CUSTOMER_CONFIRMATION_SMS=false
