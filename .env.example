NEXT_PUBLIC_SITE_URL=https://bhoomikonnect.com
NEXT_PUBLIC_PRIMARY_PHONE=+91 90000 00000
NEXT_PUBLIC_WHATSAPP_NUMBER=919000000000

# Directus CMS
# Use DIRECTUS_URL for server-side fetches. NEXT_PUBLIC_DIRECTUS_URL is only needed
# if you want Next/Image to allow Directus asset URLs at build time.
DIRECTUS_URL=https://your-directus-instance.example.com
NEXT_PUBLIC_DIRECTUS_URL=https://your-directus-instance.example.com
DIRECTUS_STATIC_TOKEN=
DIRECTUS_CACHE_SECONDS=60

# Optional Supabase runtime
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Transactional email and administrator identity
RESEND_API_KEY=
RESEND_FROM_EMAIL=BhoomiKonnect <leads@your-domain.com>
ADMIN_EMAIL=admin@example.com

# Local development only. These values are ignored by production authentication.
LOCAL_ADMIN_EMAIL=
LOCAL_ADMIN_PASSWORD=
LOCAL_ADMIN_SESSION_SECRET=
